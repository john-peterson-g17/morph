{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Morph Job",
  "description": "Schema for morph backfill job configuration files",
  "type": "object",
  "required": ["version", "job", "connection", "source", "steps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "enum": ["v1"],
      "description": "Schema version"
    },
    "job": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Unique name for this backfill job"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the job"
        }
      }
    },
    "connection": {
      "type": "object",
      "required": ["driver", "dsn_env"],
      "additionalProperties": false,
      "properties": {
        "driver": {
          "type": "string",
          "enum": ["postgres"],
          "description": "Database driver"
        },
        "dsn_env": {
          "type": "string",
          "minLength": 1,
          "description": "Environment variable containing the database connection string"
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["window", "chunking"],
      "additionalProperties": false,
      "properties": {
        "schema": {
          "type": "string",
          "description": "Source database schema"
        },
        "window": {
          "type": "object",
          "required": ["start", "end"],
          "additionalProperties": false,
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time",
              "description": "Start of the time window (RFC 3339)"
            },
            "end": {
              "type": "string",
              "format": "date-time",
              "description": "End of the time window (RFC 3339)"
            }
          }
        },
        "chunking": {
          "type": "object",
          "required": ["strategy", "column"],
          "additionalProperties": false,
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["time_range"],
              "description": "Chunking strategy"
            },
            "column": {
              "type": "string",
              "minLength": 1,
              "description": "Column used for chunking"
            },
            "initial_width": {
              "type": "string",
              "pattern": "^[0-9]+(ms|s|m|h)$",
              "description": "Starting chunk width (e.g. 30m, 1h)"
            },
            "min_width": {
              "type": "string",
              "pattern": "^[0-9]+(ms|s|m|h)$",
              "description": "Minimum adaptive chunk width"
            },
            "max_width": {
              "type": "string",
              "pattern": "^[0-9]+(ms|s|m|h)$",
              "description": "Maximum adaptive chunk width"
            },
            "target_runtime": {
              "type": "string",
              "pattern": "^[0-9]+(ms|s|m|h)$",
              "description": "Target runtime per chunk"
            }
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "concurrency": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of parallel chunk workers"
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum retries per failed chunk"
        },
        "max_rows": {
          "type": "integer",
          "minimum": 0,
          "description": "Soft cap on total rows (0 = no limit)"
        },
        "dry_run": {
          "type": "boolean",
          "description": "Print the plan without executing"
        }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the progress tracking file"
        },
        "fresh": {
          "type": "boolean",
          "description": "Delete progress file and start from scratch"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "statement_timeout": {
          "type": "string",
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "description": "Maximum statement execution time"
        },
        "truncate_targets": {
          "type": "boolean",
          "description": "Truncate target tables before loading"
        },
        "drop_indexes": {
          "type": "boolean",
          "description": "Drop non-PK/non-unique indexes before loading"
        },
        "rebuild_indexes": {
          "type": "boolean",
          "description": "Recreate indexes after loading"
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of backfill steps",
      "items": {
        "type": "object",
        "required": ["name", "target", "sql"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Unique step name"
          },
          "target": {
            "type": "object",
            "required": ["table"],
            "additionalProperties": false,
            "properties": {
              "schema": {
                "type": "string",
                "description": "Target database schema"
              },
              "table": {
                "type": "string",
                "minLength": 1,
                "description": "Target table name"
              }
            }
          },
          "sql": {
            "type": "string",
            "minLength": 1,
            "description": "SQL statement to execute. Use $1 and $2 for chunk window start/end"
          }
        }
      }
    }
  }
}
