{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Morph Job",
  "description": "Schema for morph backfill job configuration files",
  "type": "object",
  "required": ["version", "job", "connection", "partitioning", "steps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "enum": ["v1"],
      "description": "Schema version"
    },
    "job": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Unique name for this backfill job"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the job"
        }
      }
    },
    "connection": {
      "type": "object",
      "required": ["driver", "dsn_env"],
      "additionalProperties": false,
      "properties": {
        "driver": {
          "type": "string",
          "enum": ["postgres"],
          "description": "Database driver"
        },
        "dsn_env": {
          "type": "string",
          "minLength": 1,
          "description": "Environment variable containing the database connection string"
        }
      }
    },
    "partitioning": {
      "type": "object",
      "required": ["strategy", "window"],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["time_range"],
          "description": "Partitioning strategy"
        },
        "window": {
          "type": "object",
          "required": ["start", "end"],
          "additionalProperties": false,
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time",
              "description": "Start of the time window (RFC 3339)"
            },
            "end": {
              "type": "string",
              "format": "date-time",
              "description": "End of the time window (RFC 3339)"
            }
          }
        },
        "adaptive": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "initial_width": {
              "type": "string",
              "pattern": "^[0-9]+(ms|s|m|h)$",
              "description": "Starting chunk width (e.g. 30m, 1h)"
            },
            "min_width": {
              "type": "string",
              "pattern": "^[0-9]+(ms|s|m|h)$",
              "description": "Minimum adaptive chunk width"
            },
            "max_width": {
              "type": "string",
              "pattern": "^[0-9]+(ms|s|m|h)$",
              "description": "Maximum adaptive chunk width"
            },
            "target_runtime": {
              "type": "string",
              "pattern": "^[0-9]+(ms|s|m|h)$",
              "description": "Target runtime per chunk"
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "concurrency": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of parallel chunk workers"
            },
            "max_retries": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum retries per failed chunk"
            },
            "max_rows": {
              "type": "integer",
              "minimum": 0,
              "description": "Soft cap on total rows (0 = no limit)"
            },
            "statement_timeout": {
              "type": "string",
              "pattern": "^[0-9]+(ms|s|m|h)$",
              "description": "Maximum statement execution time"
            }
          }
        }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the progress tracking file"
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of backfill steps",
      "items": {
        "type": "object",
        "required": ["name", "morph"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Unique step name"
          },
          "before": {
            "type": "array",
            "description": "SQL statements to run once before the morph chunked processing begins (e.g. drop indexes)",
            "items": {
              "type": "object",
              "required": ["sql"],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Optional label for this statement"
                },
                "sql": {
                  "type": "string",
                  "minLength": 1,
                  "description": "SQL statement to execute"
                }
              }
            }
          },
          "morph": {
            "type": "object",
            "required": ["partition_by", "from", "into"],
            "additionalProperties": false,
            "properties": {
              "partition_by": {
                "type": "string",
                "minLength": 1,
                "description": "Column used for time-range partitioning"
              },
              "from": {
                "type": "object",
                "required": ["sql"],
                "additionalProperties": false,
                "properties": {
                  "sql": {
                    "type": "string",
                    "minLength": 1,
                    "description": "SELECT query to read source data"
                  }
                }
              },
              "into": {
                "type": "object",
                "required": ["sql"],
                "additionalProperties": false,
                "properties": {
                  "sql": {
                    "type": "string",
                    "minLength": 1,
                    "description": "INSERT statement with optional ON CONFLICT clause"
                  }
                }
              }
            }
          },
          "after": {
            "type": "array",
            "description": "SQL statements to run once after the morph chunked processing completes (e.g. create indexes)",
            "items": {
              "type": "object",
              "required": ["sql"],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Optional label for this statement"
                },
                "sql": {
                  "type": "string",
                  "minLength": 1,
                  "description": "SQL statement to execute"
                }
              }
            }
          }
        }
      }
    }
  }
}
